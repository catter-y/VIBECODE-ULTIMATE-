-- =====================
-- Constants & State
-- =====================
local PLAYER_NAME = LocalPlayer.Name
local PLAYER_ID   = tostring(LocalPlayer.UserId)
local IGNORED_FOLDERS = { Hills = true, Staircase = true }

local remoteModeActive = false
local loopDelay        = 0.01 -- Dropped to 0.01 for MAX SPEED
local ascendActive     = false
local fruitValueActive = false
local autoLemonPickActive = false

local watchConnections = {}
local activeRemotes    = {}
local activeRemoteSet  = {}
local currentTycoon    = nil

-- =====================
-- Helpers
-- =====================
local function getTycoons()
    local tycoons = {}
    for _, child in ipairs(workspace:GetChildren()) do
        if child.Name:match("^Tycoon") then
            table.insert(tycoons, child)
        end
    end
    return tycoons
end

local function isOwnedByLocalPlayer(tycoon)
    local o = tycoon:FindFirstChild("Owner")
    if not o then return false end
    local v = tostring(o.Value)
    return v == PLAYER_NAME or v == PLAYER_ID
end

local function getPlayerTycoon()
    for _, t in ipairs(getTycoons()) do
        if isOwnedByLocalPlayer(t) then return t end
    end
end

-- =====================
-- Active Remote Set (Auto Buy)
-- =====================
local function addActive(rf)
    if not activeRemoteSet[rf] then
        activeRemoteSet[rf] = true
        activeRemotes[#activeRemotes + 1] = rf
    end
end

local function disconnectAll()
    for _, c in ipairs(watchConnections) do c:Disconnect() end
    watchConnections = {}
    table.clear(activeRemotes)
    table.clear(activeRemoteSet)
    currentTycoon = nil
end

local function connectToTycoon(tycoon)
    local purchases = tycoon:FindFirstChild("Purchases")
    if not purchases then return end
    
    currentTycoon = tycoon
    
    local function processDescendant(obj)
        if obj.Name == "Purchase" and obj:IsA("RemoteFunction") then
            addActive(obj) -- Adds unconditionally for maximum compatibility
        end
    end

    for _, obj in ipairs(purchases:GetDescendants()) do
        processDescendant(obj)
    end
    
    local c = purchases.DescendantAdded:Connect(processDescendant)
    watchConnections[#watchConnections + 1] = c
end

local function findAndConnect()
    local t = getPlayerTycoon()
    if t then connectToTycoon(t) end
end

findAndConnect()

workspace.ChildAdded:Connect(function(child)
    if child.Name:match("^Tycoon") and isOwnedByLocalPlayer(child) then
        disconnectAll()
        connectToTycoon(child)
    end
end)

workspace.ChildRemoved:Connect(function(child)
    if child == currentTycoon then disconnectAll() end
end)

-- =====================
-- Blaster Loop (OPTIMIZED FOR MAX SPEED)
-- =====================
task.spawn(function()
    while true do
        if remoteModeActive then
            local count = #activeRemotes
            if count > 0 then
                for i = 1, count do
                    local rf = activeRemotes[i]
                    if rf and rf.Parent then
                        -- Fires concurrently for maximum speed
                        task.spawn(function()
                            pcall(function()
                                rf:InvokeServer()
                            end)
                        end)
                    end
                end
            end
        end
        task.wait(loopDelay)
    end
end)

-- =====================
-- Anti-Lag
-- =====================
local function cleanupTycoonAssets(purchasesFolder)
    for _, category in ipairs(purchasesFolder:GetChildren()) do
        if not IGNORED_FOLDERS[category.Name] then
            for _, item in ipairs(category:GetChildren()) do
                if item.Name ~= "Buttons" and item:IsA("Folder") then
                    item:Destroy()
                end
            end
        end
    end
end

local function runAntiLag()
    local cleaned, failed = 0, 0
    for _, tycoon in ipairs(getTycoons()) do
        local purchases = tycoon:FindFirstChild("Purchases")
        if purchases then
            local ok, err = pcall(cleanupTycoonAssets, purchases)
            if ok then
                cleaned += 1
            else
                failed += 1
                warn("[Automator] " .. tycoon.Name .. " failed: " .. tostring(err))
            end
        end
    end
    return cleaned, failed
end

-- =====================
-- Purchase Sounds
-- =====================
local function getSound(path)
    local current = RS
    for _, name in ipairs(path) do
        current = current:FindFirstChild(name)
        if not current then return nil end
    end
    return current
end

local SOUND_PATHS = {
    getSound({"Modules", "Tycoon", "Entity", "Client", "ClientTycoonPurchase", "Purchase"}),
    getSound({"Modules", "Tycoon", "Entity", "Client", "ClientTycoonPurchasable", "Wind"}),
    getSound({"Modules", "Tycoon", "Entity", "Client", "ClientTycoonPurchasable", "Drop"}),
}

local validSounds = {}
for _, sound in ipairs(SOUND_PATHS) do
    if sound then table.insert(validSounds, sound) end
end
SOUND_PATHS = validSounds

local originalVolumes = {}
for _, sound in ipairs(SOUND_PATHS) do
    originalVolumes[sound] = sound.Volume
end

local function setSoundsMuted(mute)
    for _, sound in ipairs(SOUND_PATHS) do
        sound.Volume = mute and 0 or originalVolumes[sound]
    end
end

-- =====================
-- Auto Ascend
-- =====================
local function startAscend()
    task.spawn(function()
        while ascendActive do
            for _, tycoon in ipairs(getTycoons()) do
                local remotes = tycoon:FindFirstChild("Remotes")
                if remotes then
                    local ascend = remotes:FindFirstChild("Ascend")
                    if ascend then
                        task.spawn(pcall, ascend.InvokeServer, ascend)
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end

-- =====================
-- Auto Fruit Value
-- =====================
local function startFruitValue()
    task.spawn(function()
        while fruitValueActive do
            for _, tycoon in ipairs(getTycoons()) do
                local remotes = tycoon:FindFirstChild("Remotes")
                if remotes then
                    local upgradePower = remotes:FindFirstChild("UpgradePowerLevel")
                    if upgradePower then
                        task.spawn(pcall, upgradePower.InvokeServer, upgradePower, "ClickFruitValue")
                    end
                end
            end
            task.wait(0.3)
        end
    end)
end

-- =====================
-- Auto Lemon Pick (REWRITTEN: 100% robust detection & teleportation)
-- =====================
local function startAutoLemonPick()
    task.spawn(function()
        while autoLemonPickActive do
            local success, err = pcall(function()
                local character = LocalPlayer.Character
                if not character or not character:FindFirstChild("HumanoidRootPart") then
                    task.wait(0.5)
                    return
                end
                local hrp = character.HumanoidRootPart
                
                local processedAny = false
                
                for _, tycoon in ipairs(getTycoons()) do
                    if not autoLemonPickActive then break end
                    
                    -- 1. Find ALL visible fruits in the tycoon (Bypasses folder structure issues completely)
                    local allFruits = {}
                    for _, desc in ipairs(tycoon:GetDescendants()) do
                        if desc:IsA("BasePart") and desc.Name == "Fruit" and desc.Transparency < 1 then
                            table.insert(allFruits, desc)
                        end
                    end
                    
                    if #allFruits == 0 then continue end
                    processedAny = true
                    
                    -- 2. Group by Tree (Parent Model)
                    local trees = {}
                    local treeHasShiny = {}
                    for _, fruit in ipairs(allFruits) do
                        local tree = fruit.Parent
                        -- Find the first Model ancestor
                        while tree and not tree:IsA("Model") and tree ~= tycoon and tree ~= workspace do
                            tree = tree.Parent
                        end
                        if not tree or not tree:IsA("Model") then tree = fruit.Parent end
                        
                        if not trees[tree] then
                            trees[tree] = {}
                            treeHasShiny[tree] = false
                        end
                        table.insert(trees[tree], fruit)
                        
                        -- Check if shiny (Neon material or SpecialAttachment)
                        if fruit.Material == Enum.Material.Neon or fruit:FindFirstChild("SpecialAttachment") then
                            treeHasShiny[tree] = true
                        end
                    end
                    
                    -- 3. Sort trees: Shiny first, then by fruit count
                    local sortedTrees = {}
                    for tree, _ in pairs(trees) do
                        table.insert(sortedTrees, tree)
                    end
                    table.sort(sortedTrees, function(a, b)
                        if treeHasShiny[a] and not treeHasShiny[b] then return true end
                        if not treeHasShiny[a] and treeHasShiny[b] then return false end
                        return #trees[a] > #trees[b]
                    end)
                    
                    -- 4. Process each tree
                    for _, tree in ipairs(sortedTrees) do
                        if not autoLemonPickActive then break end
                        
                        local fruits = trees[tree]
                        
                        -- Sort fruits in this specific tree: Shiny first!
                        table.sort(fruits, function(a, b)
                            local aShiny = a.Material == Enum.Material.Neon or a:FindFirstChild("SpecialAttachment")
                            local bShiny = b.Material == Enum.Material.Neon or b:FindFirstChild("SpecialAttachment")
                            if aShiny and not bShiny then return true end
                            if not aShiny and bShiny then return false end
                            return false
                        end)
                        
                        -- Teleport to the tree's center first
                        local center, size = tree:GetBoundingBox()
                        hrp.CFrame = CFrame.new(center + Vector3.new(0, size.Y/2 + 5, 0))
                        task.wait(0.1) -- Let it render/register
                        
                        -- Collect fruits
                        for _, fruit in ipairs(fruits) do
                            if not autoLemonPickActive then break end
                            if fruit.Transparency >= 1 then continue end
                            
                            -- Teleport directly to the fruit to guarantee ClickDetector range
                            hrp.CFrame = fruit.CFrame + Vector3.new(0, 3, 2)
                            
                            -- Find ClickDetector (checks fruit, clickpart, and tree)
                            local clickDetector = fruit:FindFirstChildOfClass("ClickDetector")
                            if not clickDetector then
                                local clickPart = fruit:FindFirstChild("ClickPart")
                                if clickPart then
                                    clickDetector = clickPart:FindFirstChildOfClass("ClickDetector")
                                end
                            end
                            if not clickDetector then
                                clickDetector = tree:FindFirstChildOfClass("ClickDetector")
                            end
                            
                            if clickDetector then
                                pcall(fireclickdetector, clickDetector)
                                pcall(function() clickDetector:Click() end) -- Fallback
                            end
                            task.wait(0.4) -- 0.4s cooldown
                        end
                    end
                end
                
                if not processedAny then
                    task.wait(1) -- Wait longer if no fruits are currently visible
                end
            end)
            
            if not success then
                warn("[Auto Lemon Pick Error] " .. tostring(err))
            end
            
            task.wait(0.2)
        end
    end)
end

