-- =====================
-- State
-- =====================

local active = false
local launchAntiLagEnabled = true
local cachedRemotes = {}
local fireCount = 0
local BATCH_LIMIT = 24
local LOOP_DELAY = 0.05
local CACHE_REFRESH = 1

-- =====================
-- Core functions (each wrapped so one bad call can't kill a thread)
-- =====================

local function getPlayerTycoon()
	for i = 1, 10 do
		local tycoon = Workspace:FindFirstChild("Tycoon" .. i)
		if tycoon then
			local owner = tycoon:FindFirstChild("Owner")
			if owner and owner.Value == LocalPlayer then
				return tycoon
			end
		end
	end
	return nil
end

local function rebuildCache()
	local tycoon = getPlayerTycoon()
	if not tycoon then
		if #cachedRemotes > 0 then table.clear(cachedRemotes) end
		return
	end

	local purchases = tycoon:FindFirstChild("Purchases")
	if not purchases then
		if #cachedRemotes > 0 then table.clear(cachedRemotes) end
		return
	end

	local list = {}
	local descendants = purchases:GetDescendants()
	for i = 1, #descendants do
		local obj = descendants[i]
		if obj.Name == "Purchase" and obj:IsA("RemoteFunction") then
			list[#list + 1] = obj
		end
	end
	cachedRemotes = list
end

local function cleanupAllTycoons()
	local cleaned = 0
	for i = 1, 10 do
		local tycoon = Workspace:FindFirstChild("Tycoon" .. i)
		if tycoon then
			local purchases = tycoon:FindFirstChild("Purchases")
			if purchases then
				for _, category in ipairs(purchases:GetChildren()) do
					if category.Name ~= "Hills" and category.Name ~= "Staircase" then
						for _, item in ipairs(category:GetChildren()) do
							if item.Name ~= "Buttons" and item:IsA("Folder") then
								item:Destroy()
								cleaned += 1
							end
						end
					end
				end
			end
		end
	end
	return cleaned
end

local function runAntiLag(showFeedback)
	if showFeedback then
		AntiLagBtn.Text = "Running..."
		AntiLagBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
	end

	local ok, cleaned = pcall(cleanupAllTycoons)
	cleaned = ok and cleaned or 0

	if showFeedback then
		AntiLagBtn.Text = "Done! (" .. cleaned .. ")"
		AntiLagBtn.BackgroundColor3 = Color3.fromRGB(30, 160, 30)
		task.delay(2, function()
			AntiLagBtn.Text = "ANTI-LAG"
			AntiLagBtn.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
		end)
	end

	return cleaned
end

-- =====================
-- Background threads — self-healing: any error is caught and the loop
-- continues instead of silently dying, which was the cause of random stops
-- =====================

-- Cache rebuilder
task.spawn(function()
	while ScreenGui.Parent do
		local ok, err = pcall(rebuildCache)
		if not ok then
			warn("[TycoonAuto] cache rebuild error: " .. tostring(err))
		end
		task.wait(CACHE_REFRESH)
	end
end)

-- Watchdog: if AUTO is ON but cache is empty for too long, force a tycoon
-- re-detect (handles tycoon resets / rebirths that wipe Purchases)
local emptyCacheTicks = 0
task.spawn(function()
	while ScreenGui.Parent do
		task.wait(2)
		if active then
			if #cachedRemotes == 0 then
				emptyCacheTicks += 1
				if emptyCacheTicks >= 3 then
					pcall(rebuildCache)
					emptyCacheTicks = 0
				end
			else
				emptyCacheTicks = 0
			end
		end
	end
end)

-- Main fire loop
task.spawn(function()
	while ScreenGui.Parent do
		task.wait(LOOP_DELAY)

		if active and #cachedRemotes > 0 then
			local ok, err = pcall(function()
				local fired = 0
				local count = #cachedRemotes

				for i = 1, count do
					if not active then break end
					local rf = cachedRemotes[i]
					if rf and rf.Parent then
						local base = rf.Parent:FindFirstChild("Base")
						if base then
							fired += 1
							fireCount += 1
							task.spawn(function()
								pcall(rf.InvokeServer, rf)
							end)
							if fired >= BATCH_LIMIT then
								task.wait()
								fired = 0
							end
						end
					end
				end
			end)

			if not ok then
				warn("[TycoonAuto] fire loop error: " .. tostring(err))
			end

			StatusLabel.Text = "Fired: " .. fireCount
		end
	end
end)

