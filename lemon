-- Constants & State
-- =====================

local PLAYER_NAME = LocalPlayer.Name
local PLAYER_ID   = tostring(LocalPlayer.UserId)
local IGNORED_FOLDERS = { Hills = true, Staircase = true }

local remoteModeActive = false
local loopDelay        = 0.1
local ascendActive     = false
local fruitValueActive = false
local shinyLemonActive = false
local watchConnections = {}
local activeRemotes    = {}
local activeRemoteSet  = {}
local currentTycoon    = nil

-- =====================
-- Helpers
-- =====================

local function getTycoons()
    local tycoons = {}
    for _, child in ipairs(workspace:GetChildren()) do
        if child.Name:match("^Tycoon") then
            table.insert(tycoons, child)
        end
    end
    return tycoons
end

local function isOwnedByLocalPlayer(tycoon)
    local o = tycoon:FindFirstChild("Owner")
    if not o then return false end
    local v = tostring(o.Value)
    return v == PLAYER_NAME or v == PLAYER_ID
end

local function getPlayerTycoon()
    for _, t in ipairs(getTycoons()) do
        if isOwnedByLocalPlayer(t) then return t end
    end
end

-- =====================
-- Active Remote Set
-- =====================

local function addActive(rf)
    if not activeRemoteSet[rf] then
        activeRemoteSet[rf] = true
        activeRemotes[#activeRemotes + 1] = rf
    end
end

local function removeActive(rf)
    if activeRemoteSet[rf] then
        activeRemoteSet[rf] = nil
        for i = #activeRemotes, 1, -1 do
            if activeRemotes[i] == rf then
                activeRemotes[i] = activeRemotes[#activeRemotes]
                activeRemotes[#activeRemotes] = nil
                break
            end
        end
    end
end

local function watchRemote(rf)
    local parent = rf.Parent
    if not parent then return end

    if parent:FindFirstChild("Base") then addActive(rf) end

    local c1 = parent.ChildAdded:Connect(function(child)
        if child.Name == "Base" then addActive(rf) end
    end)
    local c2 = parent.ChildRemoved:Connect(function(child)
        if child.Name == "Base" then removeActive(rf) end
    end)

    watchConnections[#watchConnections + 1] = c1
    watchConnections[#watchConnections + 1] = c2
end

local function disconnectAll()
    for _, c in ipairs(watchConnections) do c:Disconnect() end
    watchConnections = {}
    table.clear(activeRemotes)
    table.clear(activeRemoteSet)
    currentTycoon = nil
end

local function connectToTycoon(tycoon)
    local purchases = tycoon:FindFirstChild("Purchases")
    if not purchases then return end

    currentTycoon = tycoon

    for _, obj in ipairs(purchases:GetDescendants()) do
        if obj.Name == "Purchase" and obj:IsA("RemoteFunction") then
            watchRemote(obj)
        end
    end

    local c = purchases.DescendantAdded:Connect(function(obj)
        if obj.Name == "Purchase" and obj:IsA("RemoteFunction") then
            watchRemote(obj)
        end
    end)
    watchConnections[#watchConnections + 1] = c
end

local function findAndConnect()
    local t = getPlayerTycoon()
    if t then connectToTycoon(t) end
end

findAndConnect()

workspace.ChildAdded:Connect(function(child)
    if child.Name:match("^Tycoon") and isOwnedByLocalPlayer(child) then
        disconnectAll()
        connectToTycoon(child)
    end
end)

workspace.ChildRemoved:Connect(function(child)
    if child == currentTycoon then disconnectAll() end
end)

-- =====================
-- Blaster Loop
-- =====================

task.spawn(function()
    while true do
        pcall(function()
            if not remoteModeActive then
                task.wait(0.1)
                return
            end

            local count = #activeRemotes
            if count == 0 then
                task.wait(0.1)
                return
            end

            for i = 1, count do
                local rf = activeRemotes[i]
                if rf and rf.Parent then
                    task.spawn(pcall, rf.InvokeServer, rf)
                end
            end

            task.wait(loopDelay)
        end)
    end
end)

-- =====================
-- Anti-Lag
-- =====================

local function cleanupTycoonAssets(purchasesFolder)
    for _, category in ipairs(purchasesFolder:GetChildren()) do
        if not IGNORED_FOLDERS[category.Name] then
            for _, item in ipairs(category:GetChildren()) do
                if item.Name ~= "Buttons" and item:IsA("Folder") then
                    item:Destroy()
                end
            end
        end
    end
end

local function runAntiLag()
    local cleaned, failed = 0, 0
    for _, tycoon in ipairs(getTycoons()) do
        local purchases = tycoon:FindFirstChild("Purchases")
        if purchases then
            local ok, err = pcall(cleanupTycoonAssets, purchases)
            if ok then
                cleaned += 1
            else
                failed += 1
                warn("[Automator] " .. tycoon.Name .. " failed: " .. tostring(err))
            end
        end
    end
    return cleaned, failed
end

-- =====================
-- Purchase Sounds
-- =====================

local function getSound(path)
    local current = RS
    for _, name in ipairs(path) do
        current = current:FindFirstChild(name)
        if not current then return nil end
    end
    return current
end

local SOUND_PATHS = {
    getSound({"Modules", "Tycoon", "Entity", "Client", "ClientTycoonPurchase", "Purchase"}),
    getSound({"Modules", "Tycoon", "Entity", "Client", "ClientTycoonPurchasable", "Wind"}),
    getSound({"Modules", "Tycoon", "Entity", "Client", "ClientTycoonPurchasable", "Drop"}),
}

local validSounds = {}
for _, sound in ipairs(SOUND_PATHS) do
    if sound then
        table.insert(validSounds, sound)
    end
end
SOUND_PATHS = validSounds

local originalVolumes = {}
for _, sound in ipairs(SOUND_PATHS) do
    originalVolumes[sound] = sound.Volume
end

local function setSoundsMuted(mute)
    for _, sound in ipairs(SOUND_PATHS) do
        sound.Volume = mute and 0 or originalVolumes[sound]
    end
end

-- =====================
-- Auto Ascend
-- =====================

local function startAscend()
    task.spawn(function()
        while ascendActive do
            for _, tycoon in ipairs(getTycoons()) do
                local remotes = tycoon:FindFirstChild("Remotes")
                if remotes then
                    local ascend = remotes:FindFirstChild("Ascend")
                    if ascend then
                        task.spawn(pcall, ascend.InvokeServer, ascend)
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end

-- =====================
-- Auto Fruit Value
-- =====================

local function startFruitValue()
    task.spawn(function()
        while fruitValueActive do
            for _, tycoon in ipairs(getTycoons()) do
                local remotes = tycoon:FindFirstChild("Remotes")
                if remotes then
                    local upgradePower = remotes:FindFirstChild("UpgradePowerLevel")
                    if upgradePower then
                        task.spawn(pcall, upgradePower.InvokeServer, upgradePower, "ClickFruitValue")
                    end
                end
            end
            task.wait(0.3)
        end
    end)
end

-- =====================
-- Auto Collect Shiny Lemons
-- =====================

local function startShinyLemonCollector()
    task.spawn(function()
        while shinyLemonActive do
            pcall(function()
                local character = LocalPlayer.Character
                if not character or not character:FindFirstChild("HumanoidRootPart") then
                    task.wait(0.1)
                    return
                end

                local hrp = character.HumanoidRootPart
                local oldPos = hrp.CFrame

                for _, tycoon in ipairs(getTycoons()) do
                    if not shinyLemonActive then break end

                    local constant = tycoon:FindFirstChild("Constant")
                    if constant then
                        local trees = constant:FindFirstChild("Trees")
                        if trees then
                            for _, tree in ipairs(trees:GetChildren()) do
                                if not shinyLemonActive then break end

                                for _, item in ipairs(tree:GetChildren()) do
                                    if not shinyLemonActive then break end

                                    if item.Name == "Fruit" then
                                        local hasSpecial = item:FindFirstChild("SpecialAttachment") ~= nil
                                        local isNeon = item.Material == Enum.Material.Neon

                                        if hasSpecial and isNeon then
                                            hrp.CFrame = item.CFrame + item.CFrame.LookVector * 5
                                            task.wait(0.1)

                                            local clickPart = item:FindFirstChild("ClickPart")
                                            if clickPart then
                                                local clickDetector = clickPart:FindFirstChildOfClass("ClickDetector")
                                                if clickDetector then
                                                    pcall(fireclickdetector, clickDetector)
                                                end
                                            end

                                            task.wait(0.5)
                                        end
                                    end
                                end
                            end
                        end
                    end
                end

                if shinyLemonActive then
                    hrp.CFrame = oldPos
                end
            end)
            task.wait(1)
        end
    end)
end

