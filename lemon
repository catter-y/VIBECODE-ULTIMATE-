-- Button Callbacks
-- =====================

CloseBtn.MouseButton1Click:Connect(function()
	active = false
	ScreenGui:Destroy()
end)

ToggleBtn.MouseButton1Click:Connect(function()
	active = not active
	if active then
		pcall(rebuildCache) -- instant refresh on enable, no startup delay
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		ToggleBtn.Text = "AUTO: ON"
		StatusLabel.Text = "Fired: " .. fireCount
	else
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
		ToggleBtn.Text = "AUTO: OFF"
		StatusLabel.Text = "Idle"
	end
end)

AntiLagBtn.MouseButton1Click:Connect(function()
	runAntiLag(true)
end)

LaunchAntiLagBtn.MouseButton1Click:Connect(function()
	launchAntiLagEnabled = not launchAntiLagEnabled
	if launchAntiLagEnabled then
		LaunchAntiLagBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		LaunchAntiLagBtn.Text = "LAUNCH ANTI-LAG: ON"
	else
		LaunchAntiLagBtn.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
		LaunchAntiLagBtn.Text = "LAUNCH ANTI-LAG: OFF"
	end
end)

-- =====================
-- Run anti-lag once immediately on script execution, only if toggle is on
-- =====================

task.spawn(function()
	task.wait(0.5) -- brief delay so tycoon has a chance to be loaded/owned
	if launchAntiLagEnabled then
		runAntiLag(false)
	end
end)
