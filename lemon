Tab:CreateSection("Performance")

local autoLagCleanup = false

Tab:CreateToggle({
	Name = "Auto-Run Anti-Lag on Startup",
	CurrentValue = false,
	Flag = "AutoLag",
	Callback = function(Value)
		autoLagCleanup = Value
		if Value then
			-- Run anti-lag immediately
			local cleaned, failed = 0, 0
			for i = 1, 10 do
				local tycoon = workspace:FindFirstChild("Tycoon" .. i)
				if tycoon then
					local purchases = tycoon:FindFirstChild("Purchases")
					if purchases then
						local ok, err = pcall(cleanupTycoonAssets, purchases)
						if ok then cleaned += 1
						else
							failed += 1
							warn("[Automator] Tycoon" .. i .. " failed: " .. tostring(err))
						end
					end
				end
			end
			Rayfield:Notify({ Title = "Anti-Lag", Content = "Cleaned " .. cleaned .. " tycoon(s)!", Duration = 4, Image = "trash-2" })
		end
	end,
})

Tab:CreateButton({
	Name = "Run Anti-Lag Now (All Tycoons)",
	Callback = function()
		local cleaned, failed = 0, 0
		for i = 1, 10 do
			local tycoon = workspace:FindFirstChild("Tycoon" .. i)
			if tycoon then
				local purchases = tycoon:FindFirstChild("Purchases")
				if purchases then
					local ok, err = pcall(cleanupTycoonAssets, purchases)
					if ok then cleaned += 1
					else
						failed += 1
						warn("[Automator] Tycoon" .. i .. " failed: " .. tostring(err))
					end
				end
			end
		end

		if cleaned == 0 and failed == 0 then
			Rayfield:Notify({ Title = "Anti-Lag", Content = "No tycoons found.", Duration = 4, Image = "search-x" })
		elseif failed > 0 then
			Rayfield:Notify({ Title = "Anti-Lag", Content = "Cleaned " .. cleaned .. ", failed " .. failed .. ".", Duration = 5, Image = "alert-triangle" })
		else
			Rayfield:Notify({ Title = "Anti-Lag", Content = "Cleaned " .. cleaned .. " tycoon(s)!", Duration = 4, Image = "trash-2" })
		end
	end,
})

